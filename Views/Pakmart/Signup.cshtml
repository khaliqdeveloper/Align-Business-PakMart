<div class="container mt-5 mb-5">
    <div class="card p-4 shadow-lg">
        <h3 class="text-center mb-3 text-success fw-bold">Register</h3>
        <form>
            <div class="mb-3">
                <label class="form-label">Country / Region</label>
                <select class="form-select">
                    <option selected>Pakistan</option>
                    <option>United States</option>
                    <option>United Kingdom</option>
                </select>
            </div>
            <div class="mb-3">
                <label class="form-label">Trade Role</label><br>
                <div class="form-check form-check-inline">
                    <input class="form-check-input" type="radio" name="tradeRole" value="Buyer"> Buyer
                </div>
                <div class="form-check form-check-inline">
                    <input class="form-check-input" type="radio" name="tradeRole" value="Seller"> Seller
                </div>
                <div class="form-check form-check-inline">
                    <input class="form-check-input" type="radio" name="tradeRole" value="Both"> Both
                </div>
            </div>
            <div class="mb-3">
                <label class="form-label">Email</label>
                <input type="email" class="form-control" placeholder="Enter your email">
            </div>
            <div class="mb-3">
                <label class="form-label">Password</label>
                <input type="password" class="form-control" placeholder="Set your password">
            </div>
            <div class="mb-3">
                <label class="form-label">Confirm Password</label>
                <input type="password" class="form-control" placeholder="Confirm your password">
            </div>
            <div class="mb-3">
                <label class="form-label">Company Name</label>
                <input type="text" class="form-control" placeholder="Enter your company name">
            </div>
            <div class="mb-3">
                <label class="form-label">Full Name</label>
                <div class="row">
                    <div class="col-md-6">
                        <input type="text" class="form-control" placeholder="First name">
                    </div>
                    <div class="col-md-6">
                        <input type="text" class="form-control" placeholder="Last name">
                    </div>
                </div>
            </div>
            <div class="mb-3">
                <label class="form-label">Phone Number</label>
                <div class="row">
                    <div class="col-md-3">
                        <input type="text" class="form-control" placeholder="Code">
                    </div>
                    <div class="col-md-9">
                        <input type="text" class="form-control" placeholder="Phone number">
                    </div>
                </div>
            </div>
            <div class="mb-3 form-check">
                <input type="checkbox" class="form-check-input">
                <label class="form-check-label">I agree to the <a href="#">Terms & Conditions</a></label>
            </div>
            <button type="submit" class="btn btn-success w-100">Create an account</button>
        </form>
    </div>
</div>
